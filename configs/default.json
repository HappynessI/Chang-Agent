{
  "inference_only": true,
  "max_steps": 8,
  "agent_model": "Qwen/Qwen3-VL-2B-Instruct",
  "agent_max_new_tokens": 160,
  "coordinate_protocol": "public_normalized_0_1000_internal_pixel_xy",
  "initialization": "fresh_sam3_dual_view_text_prompt",
  "selection_policy": "conservative_best",
  "selection_epsilon": 0.0,
  "max_selection_area_delta": 0.25,
  "matching_mode": "overlap_presence",
  "instance_overlap_threshold": 0.25,
  "t12_min_instance_area": 0,
  "cd_min_instance_area": 0,
  "verifier": {
    "type": "qwen3vl_compact_delta_effect_zero_shot",
    "shared_agent_weights": true,
    "max_new_tokens": 1024,
    "max_region_proposals": 6,
    "max_delta_regions_per_batch": 3,
    "candidate_evidence_modes": ["mask_context", "rgb_temporal_state"],
    "decision": "programmatic_initial_and_batched_candidate_from_rgb_temporal_state"
  },
  "seed": 42
}
