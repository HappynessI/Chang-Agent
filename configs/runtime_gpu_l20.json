{
  "environment": "omniovcd-env",
  "agent_model": "/Data/wyh/CD-SegAgent/models/Qwen3-VL-2B-Instruct",
  "cuda_visible_devices": "7",
  "device_map": "auto",
  "inference_only": true,
  "coordinate_protocol": "public_normalized_0_1000_internal_pixel_xy",
  "initialization": "fresh_sam3_dual_view_text_prompt",
  "verifier": "qwen3vl_zero_shot_shared_weights",
  "max_steps": 3,
  "matching_mode": "overlap_presence",
  "instance_overlap_threshold": 0.25,
  "t12_min_instance_area": 0,
  "cd_min_instance_area": 0,
  "dataset_split": "LEVIR-CD test_256 diagnostic subset",
  "seed": 42,
  "memory_policy": "single-GPU; do not expose all GPUs for smoke tests",
  "notes": "Use an execution context with /dev/nvidia* mounted; sandbox-only probes can report false CUDA availability."
}
